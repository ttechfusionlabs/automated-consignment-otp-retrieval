      "id": "18086b0f-1b4e-43a7-bb1d-a0b281a5a6d0",
      "name": "Read Input Excel (Disk)",
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1,
      "position": [
        -592,
        -224
      ],
      "notes": "Reads the .xlsx that PowerShell already saved into /files/input/ (path comes from webhook body.inputFile)."
    },
    {
      "parameters": {
        "options": {
          "headerRow": false
        }
      },
      "id": "86fe64c8-6ae2-4e9e-9e67-6df269a2b68a",
      "name": "Parse Excel -> CN Rows",
      "type": "n8n-nodes-base.spreadsheetFile",
      "typeVersion": 2,
      "position": [
        -368,
        -224
      ],
      "notes": "Converts the binary xlsx into one JSON item per row, each with a CN property."
    },
    {
      "parameters": {
        "jsCode": "const CN_PATTERN = /^ECR[0-9A-Z]+$/i;\nconst seen = new Set();\nconst cleaned = [];\nfor (const item of items) {\n  // Parse Excel node output structure: item.json.row is an array\n  // row[0]=Branch Name, row[1]=Cn, row[2]=Merchant Name, row[3]=OTP\n  const rowArr = item.json.row;\n  let raw;\n\n  if (Array.isArray(rowArr)) {\n    raw = rowArr[1]; // Column B = Cn\n    // Fallback: scan all values in the row array for CN pattern match\n    if (raw === undefined || raw === null || String(raw).trim() === '') {\n      for (const val of rowArr) {\n        if (val !== undefined && val !== null && CN_PATTERN.test(String(val).trim())) {\n          raw = val;\n          break;\n        }\n      }\n    }\n  } else {\n    // fallback for old-style flat structure, just in case\n    raw = item.json['1'];\n  }\n\n  if (raw === undefined || raw === null) continue;\n  const cn = String(raw).trim();\n  if (cn === '') continue;\n  if (!CN_PATTERN.test(cn)) continue;\n  if (!seen.has(cn)) {\n    seen.add(cn);\n    cleaned.push({ json: { CN: cn } });\n  }\n}\nreturn cleaned;"
      },
      "id": "d395f762-d908-4ec5-993a-715cea6b0c19",
      "name": "Code - Clean CN List",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -144,
        -224
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n    '{{$json.CN}}' AS CN,\n    t.verification_code AS OTP\nFROM\n    (SELECT '{{$json.CN}}' AS cn_val) AS d\nLEFT JOIN\n    tablename t\n    ON t.ref_id = d.cn_val\nLIMIT 1;",
        "options": {
          "queryReplacement": "={{$json.CN}},{{$json.CN}}"
        }
      },
      "id": "7aaff977-d0fb-45e2-a563-1b926d32762d",
      "name": "MySQL - Get OTP",
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.4,
      "position": [
        80,
        -224
      ],
      "alwaysOutputData": true,
      "credentials": {
        "mySql": {
          "id": "AyAwdCkLQM0OnI5A",
          "name": "MySQL account"
        }
      },
      "continueOnFail": true,
          },
    {
      "parameters": {
        "jsCode": "// =====================================================================\n// Final shape for the output Excel: CN | OTP\n// - If MySQL found no match, OTP will be null/undefined -> convert to ''\n// - If the MySQL node itself errored on a given item (continueOnFail),\n//   that item carries an `error` key instead of CN/OTP - handle gracefully\n//   by falling back to blank OTP rather than losing the row.\n// =====================================================================\nconst output = [];\n\nfor (const item of items) {\n  const cn = item.json.CN !== undefined ? item.json.CN : '';\n  const otpRaw = item.json.OTP;\n  const otp = (otpRaw === null || otpRaw === undefined) ? '' : String(otpRaw);\n\n  output.push({ json: { CN: cn, OTP: otp } });\n}\n\nreturn output;"
      },
      "id": "67e34d43-b445-4e3d-9f0e-9d1e6d10ab68",
      "name": "Code - Format CN|OTP Rows",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        304,
        -224
      ]
    },
    {
      "parameters": {
        "operation": "toFile",
        "fileFormat": "xlsx",
        "options": {
          "headerRow": true,
          "sheetName": "Sheet1"
        }
      },
      "id": "d32aa720-8a8a-4882-977a-0a9d888865aa",
      "name": "Build Output Excel",
      "type": "n8n-nodes-base.spreadsheetFile",
      "typeVersion": 2,
      "position": [
        528,
        -224
      ]
    },
    {
      "parameters": {
        "operation": "write",
        "fileName": "={{ $('Webhook - Receive Request').first().json.body.outputFile ? $('Webhook - Receive Request').first().json.body.outputFile : ('/files/output/' + $('Webhook - Receive Request').first().json.body.outputFileName) }}",
        "options": {}
      },
      "id": "b51b6ba1-7b76-4207-b074-97ea2f19e80c",
      "name": "Write Output Excel (Disk)",
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1,
      "position": [
        752,
        -224
      ],
      "notes": "Writes to /files/output/<outputFileName> inside the container, which is bind-mounted to C:\\n8n\\n8n-otp\\output on the Windows host."
    },
